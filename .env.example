# IMAP Configuration for DMARC reports
IMAP_HOST=mail.plain.direct
IMAP_PORT=993
IMAP_USER=reports@plain.direct
IMAP_PASSWORD=your_email_password_here
IMAP_TLS=true

# Server Configuration
PORT=3004
NODE_ENV=production

# Database path (SQLite)
DB_PATH=./data/plain-direct.db

# Cron schedule for fetching reports (every 15 minutes)
FETCH_CRON=*/15 * * * *
